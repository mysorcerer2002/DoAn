@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceArrowThickness 1.4
skinparam sequence {
  ParticipantBackgroundColor #DBEAFE
  ParticipantBorderColor #1E3A8A
  LifeLineBorderColor #1E3A8A
  NoteBackgroundColor #FEF3C7
  NoteBorderColor #D97706
}
skinparam defaultFontName "DejaVu Sans"
skinparam defaultFontSize 12
title Sơ đồ tuần tự — Đăng nhập JWT và chọn tenant

actor User as U
participant "Frontend\n(Next.js)" as FE
participant "FastAPI\n/auth/login" as API
participant "AuthService" as SVC
database "PostgreSQL" as DB

U -> FE: nhập email + password
FE -> API: POST /auth/login
activate API
API -> SVC: authenticate(email, pw)
activate SVC
SVC -> DB: SELECT user JOIN memberships
DB --> SVC: user + tenant_ids
note right of SVC
  bcrypt.checkpw(pw, hashed)
end note
SVC --> API: jwt_token (exp 1h)
deactivate SVC
API --> FE: 200 OK\naccess_token + memberships
deactivate API

note over FE
  Zustand tenant-store.setTenant(tenant_ids[0])
  axios interceptor inject X-Tenant-Id
end note

FE -> API: GET /members/me\nAuth: Bearer <jwt>, X-Tenant-Id: <tid>
activate API
note right of API
  Dependency:
  require_customer_in_tenant
  (hoặc require_owner_in_tenant)
end note
API --> FE: member profile
deactivate API
FE --> U: render dashboard

@enduml
