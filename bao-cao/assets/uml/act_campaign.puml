@startuml
skinparam backgroundColor #FFFFFF
skinparam activityBackgroundColor #DBEAFE
skinparam activityBorderColor #1E3A8A
skinparam activityDiamondBackgroundColor #FEF3C7
skinparam activityDiamondBorderColor #D97706
skinparam arrowColor #111827
skinparam defaultFontName "DejaVu Sans"
skinparam defaultFontSize 12
title Sơ đồ hoạt động — Vòng đời chiến dịch khuyến mại (NĐ 81/2018/NĐ-CP)

start
:Owner tạo campaign (draft);
:Hệ thống compute\napproval_tier + estimated_cost;
if (tier >= notify_so_ct?) then (yes)
  :Owner nộp hồ sơ Sở Công Thương;
  :status = pending_regulatory;
  :Super admin review hồ sơ;
  if (Hợp lệ?) then (yes)
    :status = approved;
  else (no)
    :status = rejected\n(kèm lý do);
    stop
  endif
else (no)
  :status = ready_to_activate;
endif

while (now < start_at?) is (chờ)
endwhile (đến giờ)

:status = active;

while (còn voucher & chưa end_at?) is (yes)
  :Khách claim voucher;
  :Staff áp dụng tại POS;
endwhile (hết quota hoặc end_at)

:status = ended;
:Cron check_post_report_overdue\n(báo cáo hậu khuyến mại 45 ngày);
:Xuất báo cáo (Điều 20 NĐ 81);
stop

@enduml
