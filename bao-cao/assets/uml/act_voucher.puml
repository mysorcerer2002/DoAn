@startuml
skinparam backgroundColor #FFFFFF
skinparam activityBackgroundColor #DBEAFE
skinparam activityBorderColor #1E3A8A
skinparam activityDiamondBackgroundColor #FEF3C7
skinparam activityDiamondBorderColor #D97706
skinparam arrowColor #111827
skinparam defaultFontName "DejaVu Sans"
skinparam defaultFontSize 12
title Sơ đồ hoạt động — Vòng đời voucher

start
:Campaign active\nkhách đủ điều kiện;
if (UPDATE quota OK?) then (yes)
  :INSERT voucher\nstatus=active;
  :Voucher hiển thị trong /member;
  fork
    :Khách đem voucher tới POS;
    :Staff quét QR, kiểm tra điều kiện;
    if (Áp dụng được?) then (yes)
      :status = used;
      :Ghi transaction POS;
    else (no)
      :trả lỗi (sai tier, hết hạn...);
    endif
  fork again
    :Cron expire_vouchers\n(định kỳ 15 phút);
    if (now > expires_at?) then (yes)
      :status = expired;
    else (no)
      :giữ nguyên status;
    endif
  end fork
else (no — hết quota)
  :Trả 409 cho client;
  stop
endif
stop

@enduml
