@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceArrowThickness 1.4
skinparam roundcorner 8
skinparam sequence {
  ActorBorderColor #1E3A8A
  ParticipantBackgroundColor #DBEAFE
  ParticipantBorderColor #1E3A8A
  LifeLineBorderColor #1E3A8A
  NoteBackgroundColor #FEF3C7
  NoteBorderColor #D97706
}
skinparam defaultFontName "DejaVu Sans"
skinparam defaultFontSize 12
title Sơ đồ tuần tự — Khách hàng claim voucher (chống TOCTOU)

actor "Khách hàng" as KH
participant "Frontend\n(Next.js /member)" as FE
participant "FastAPI\nrouter claim" as API
participant "VoucherService" as SVC
database "PostgreSQL" as DB

KH -> FE: bấm "Nhận ngay"
FE -> API: POST /campaigns/{id}/claim\nJWT + X-Tenant-Id
activate API
API -> SVC: claim(user_id, campaign_id)
activate SVC
SVC -> DB: BEGIN TRANSACTION
SVC -> DB: pg_advisory_xact_lock(hash(campaign_id))
SVC -> DB: UPDATE campaign SET issued_count=issued_count+1\nWHERE id=? AND issued_count<max_issuances
DB --> SVC: rows_affected

alt rows_affected = 1
    SVC -> DB: INSERT INTO voucher (code, member_id, ...)
    DB --> SVC: voucher_id
    SVC -> DB: COMMIT
    SVC --> API: Voucher DTO
    API --> FE: 201 Created + voucher JSON
    FE --> KH: hiển thị voucher mới
else rows_affected = 0
    SVC -> DB: ROLLBACK
    SVC --> API: CampaignQuotaExceededError
    API --> FE: 409 Conflict
end
deactivate SVC
deactivate API

note over SVC, DB
  Advisory lock + atomic UPDATE guard
  đảm bảo không vượt max_issuances
  kể cả khi N request đồng thời.
end note

@enduml
